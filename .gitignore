# ─── Gradle build output ───────────────────────────────────────────────
# A bare `build/` matches a directory named build at ANY depth, so this
# covers the root, :framework and :sample modules in one rule.
.gradle/
build/
out/
.gradletasknamecache
gradle-app.setting

# ─── Test / tooling artefacts ──────────────────────────────────────────
allure-results/
.jqwik-database

# ─── IDEs ──────────────────────────────────────────────────────────────
# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr

# Eclipse
.classpath
.project
.settings/
bin/

# Visual Studio Code
.vscode/

# ─── Java ──────────────────────────────────────────────────────────────
*.class
hs_err_pid*
replay_pid*

# BlueJ / J2ME
*.ctxt
.mtj.tmp/

# ─── Logs ──────────────────────────────────────────────────────────────
*.log

# ─── Packaged archives ─────────────────────────────────────────────────
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar
# Keep the Gradle wrapper jar so the project builds without a local Gradle install.
!gradle-wrapper.jar

# ─── Operating system files ────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Project-local, not version controlled ─────────────────────────────
/.claude
/CLAUDE.md
/docs
